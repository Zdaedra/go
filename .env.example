# ==========================================
# Site Crawler Environment Settings
# ==========================================

# Database
DATABASE_URL=postgresql+psycopg://crawler:crawler_password@postgres:5432/crawler_db

# Message Queues (Celery/Redis)
REDIS_URL=redis://redis:6379/0

# Services
ORCHESTRATOR_URL=http://orchestrator:8000
NEXT_PUBLIC_API_URL=http://localhost:8000

# Optional Settings
RECORD_VIDEO=0
