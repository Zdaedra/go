http://{$DOMAIN} {
    handle /api/* {
        uri strip_prefix /api
        reverse_proxy api:8000
    }
    
    handle /v1/* {
        reverse_proxy api:8000
    }

    handle /assets/* {
        uri strip_prefix /assets
        reverse_proxy minio:9000
    }

    handle /* {
        reverse_proxy frontend:3000
    }
}
