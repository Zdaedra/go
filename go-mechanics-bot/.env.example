PG_USER=go
PG_PASS=go_pass
PG_DB=go_bot
PG_DSN=postgresql://go:go_pass@postgres:5432/go_bot

REDIS_URL=redis://redis:6379/0

MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=minioadmin123
S3_ENDPOINT=http://minio:9000
S3_BUCKET_ARTIFACTS=artifacts
S3_BUCKET_REPORTS=reports

ORCH_URL=http://orchestrator:8080

# разные ключи доступа MinIO для разных сервисов (лучше реально разные)
ORCH_S3_ACCESS_KEY=orch_key
ORCH_S3_SECRET_KEY=orch_secret

COLLECTOR_S3_ACCESS_KEY=collector_key
COLLECTOR_S3_SECRET_KEY=collector_secret

ANALYZER_S3_ACCESS_KEY=analyzer_key
ANALYZER_S3_SECRET_KEY=analyzer_secret

IMPL_S3_ACCESS_KEY=impl_key
IMPL_S3_SECRET_KEY=impl_secret

# сайты Go (для коллектора)
OGS_USERNAME=...
OGS_PASSWORD=...

# LLM (для analyzer)
LLM_PROVIDER=openai
LLM_API_KEY=...
LLM_MODEL=...

# репозиторий, куда антигравити будет вносить изменения (для implementer)
TARGET_REPO_URL=https://github.com/yourorg/yourrepo.git
GIT_PROVIDER=github
GIT_TOKEN=...
TARGET_BASE_BRANCH=main
